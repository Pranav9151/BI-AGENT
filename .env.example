# =============================================================================
# Smart BI Agent — Environment Variables
# Architecture v3.1 — Copy to .env and fill in values
# =============================================================================
# RULE: .env contains ONLY infrastructure credentials.
#       All other secrets (LLM keys, DB creds, notif tokens) are encrypted
#       in the app database using HKDF-derived keys.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=production                      # production | development | testing
APP_NAME=Smart BI Agent
APP_VERSION=3.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=4                           # uvicorn workers (production)
LOG_LEVEL=info                          # debug | info | warning | error

# Frontend URL (for CORS whitelist — NEVER use "*")
FRONTEND_URL=https://your-domain.com
CORS_ORIGINS=["https://your-domain.com"]

# -----------------------------------------------------------------------------
# PostgreSQL — App Database
# -----------------------------------------------------------------------------
POSTGRES_USER=sbi_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=smart_bi_agent
DATABASE_URL=postgresql+asyncpg://sbi_admin:CHANGE_ME_STRONG_PASSWORD_HERE@db:5432/smart_bi_agent

# -----------------------------------------------------------------------------
# Redis (Segmented — 3 Databases)
# DB 0: Cache (degradable)    DB 1: Security (fail-closed)    DB 2: Coordination
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# -----------------------------------------------------------------------------
# Encryption — HKDF Master Key (T1, T2)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# This single key derives ALL purpose-specific encryption keys via HKDF.
# NEVER commit this value. Use Docker secrets or Vault in production.
# -----------------------------------------------------------------------------
ENCRYPTION_MASTER_KEY=CHANGE_ME_64_HEX_CHARS_HERE

# -----------------------------------------------------------------------------
# JWT — RS256 Asymmetric Keys (T4)
# Generate: ./scripts/generate_keys.sh
# Private key signs tokens. Public key verifies them.
# Algorithm is HARDCODED to RS256 — never HS256, never "none".
# -----------------------------------------------------------------------------
JWT_PRIVATE_KEY_PATH=/app/keys/private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/public.pem
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=smart-bi-agent
JWT_AUDIENCE=smart-bi-agent

# -----------------------------------------------------------------------------
# Security Settings
# -----------------------------------------------------------------------------
# Account lockout (T10)
LOCKOUT_THRESHOLD=10                    # Failed attempts before lockout
LOCKOUT_DURATION_MINUTES=30             # Lockout duration
PROGRESSIVE_DELAY_FACTOR=2              # Seconds multiplier per failed attempt

# Registration (T53)
REGISTRATION_OPEN=false                 # Closed by default — admin approval required

# WebSocket (T26, T39)
WS_MAX_CONNECTIONS_PER_USER=3
WS_AUTH_TIMEOUT_SECONDS=30
WS_MAX_MESSAGE_SIZE_BYTES=65536         # 64KB (T55)
WS_PING_INTERVAL_SECONDS=15

# Rate Limits (differentiated)
RATE_LIMIT_LLM_PER_MINUTE=10
RATE_LIMIT_SCHEMA_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_EXPORT_PER_MINUTE=5
RATE_LIMIT_DEFAULT_PER_MINUTE=100

# Session
ADMIN_SESSION_TIMEOUT_MINUTES=15

# Query limits
MAX_QUESTION_LENGTH=2000
MAX_ROWS=10000
MAX_RESULT_BYTES=52428800               # 50MB
QUERY_TIMEOUT_SECONDS=30

# Conversation limits (T37)
MAX_CONVERSATION_TURNS=20
MAX_CONVERSATION_TURN_CHARS=500

# Token budget (T36)
DEFAULT_DAILY_TOKEN_BUDGET_USER=500000
DEFAULT_DAILY_TOKEN_BUDGET_TENANT=1000000
TOKEN_BUDGET_ALERT_THRESHOLD=0.8        # Alert at 80%

# Data residency (T19)
ALLOWED_DATA_RESIDENCIES=["us","eu","local"]

# -----------------------------------------------------------------------------
# Nginx
# -----------------------------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# -----------------------------------------------------------------------------
# Ollama (optional — air-gapped deployments only)
# SECURITY: Docker internal network only, never exposed (T32)
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434     # Docker internal — NOT configurable by user
OLLAMA_ENABLED=false

# -----------------------------------------------------------------------------
# Email (SMTP) — for notifications and admin alerts
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@your-domain.com
SMTP_TLS=true

# -----------------------------------------------------------------------------
# Initial Admin Account (created by setup.sh)
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@your-domain.com
ADMIN_NAME=System Admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
